<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Document</title>
        <script src="https://cdn.jsdelivr.net/npm/@tailwindcss/browser@4"></script>
        <link rel="stylesheet" href="/Stylesheets/style.css"/>

    
</head>
<body >
    <div class="w-full h-full b-zinc-900 px-10 py-5  ">
         <div class="nav mb-10"> 
            <a class="text-blue-500 " href="/">Back to Home</a>
        </div>
        <h1 class="text-3xl tracking-tighter mb-3">All Users</h1>
     <div class="Users flex gap-5 flex-wrap">
        <% users.forEach(function(user) { %>
             <div   class="user max-w-72 p-4 bg-zinc-700 rounded-lg">
            <div class="w-full h-52 rounded-lg bg-zinc-500 ">
            <img class="w-full h-52 object-cover bg-red-500 " src="<%= user.image %>">
            </div>
            <h3 class="text-2xl tracking-tighter text-white "><%= user.name %></h3>
            <h5 class="text-zinc-500"><%= user.email %></h5>
            <div class="flex gap-3 mt-10">
                <a class="text-zinc-500 rounded-lg outline-none" href="/edit/<%= user._id %>" >Edit user</a>
                <a class="text-red-500 rounded-lg outline-none" href="/delete/<%= user._id %>" >Delete user</a>
        </div>
        </div>
        <% }) %>
       
     </div>
        
           
        
       
    </div>
    
    

    <script src="/javascript/index.js"></script>
    
</body>
</html>